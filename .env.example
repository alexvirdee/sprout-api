# ── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed origins for CORS (mobile dev tools, web).
CLIENT_ORIGINS=http://localhost:8081,http://localhost:19006

# ── Database ─────────────────────────────────────────────
# MONGODB_URI selects the cluster/ENVIRONMENT (e.g. a "sprout-dev" or
# "sprout-prod" Atlas deployment) — leave the path empty, no db name here.
# MONGODB_DB is the database the data lives in: the same ("sprout") everywhere.
# Local: mongodb://127.0.0.1:27017
# Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=sprout

# ── Auth / JWT ───────────────────────────────────────────
# Use long, random strings (e.g. `openssl rand -hex 32`). Keep them different.
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ── Google OAuth (groundwork) ────────────────────────────
# Web client ID is used to verify ID tokens sent from the mobile app.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
