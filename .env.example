# ── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed CORS origins (web / dev tools). Native apps
# are not subject to CORS, so this mainly matters for the web build.
CLIENT_ORIGIN=http://localhost:8081,http://localhost:19006

# ── Database ─────────────────────────────────────────────
# MONGODB_URI selects the cluster/environment; MONGODB_DB is the database name
# (kept the same across environments — see config/env.ts).
#   Local:  mongodb://127.0.0.1:27017
#   Atlas:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=sprout

# ── Auth ─────────────────────────────────────────────────
# A single signed JWT per session. Use a long random secret (16+ chars):
#   openssl rand -hex 32
JWT_SECRET=replace-me-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# ── Google OAuth (groundwork — not in scope yet) ─────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
